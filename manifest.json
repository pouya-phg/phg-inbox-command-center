                      "icons": [
                        { "size": 16, "url": "https://phg-inbox-command-center.vercel.app/icon-16.png" },
                        { "size": 32, "url": "https://phg-inbox-command-center.vercel.app/icon-32.png" },
                        { "size": 80, "url": "https://phg-inbox-command-center.vercel.app/icon-80.png" }
                      ],
                      "supertip": {
                        "title": "PHG AI Triage",
                        "description": "View AI priority, summary, and draft reply for this email"
