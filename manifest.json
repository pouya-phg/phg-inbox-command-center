    "full": "AI-powered email triage for Outlook. Shows priority classification, AI summaries, and generates draft replies you can copy and paste."
  },
  "icons": {
    "outline": "icon-outline.png",
    "color": "icon-color.png"
  },
  "accentColor": "#b48a46",
  "extensions": [
    {
      "requirements": {
