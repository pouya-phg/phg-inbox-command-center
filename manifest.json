        {
          "requirements": {
            "capabilities": [
              { "name": "Mailbox", "minVersion": "1.1" }
            ]
          },
          "id": "TaskPaneRuntime",
          "type": "general",
          "code": {
            "page": "https://phg-inbox-command-center.vercel.app/outlook-addon"
          }
        }
      ],
      "ribbons": [
        {
          "contexts": ["mailRead"],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "phgGroup",
                  "label": "PHG AI",
                  "icons": [
                    { "size": 16, "url": "https://phg-inbox-command-center.vercel.app/icon-16.png" },
                    { "size": 32, "url": "https://phg-inbox-command-center.vercel.app/icon-32.png" },
